# Version of Elastic products
STACK_VERSION=8.7.1


# Set the cluster name
CLUSTER_NAME=docker-cluster


# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial


# Env for ollama
OLLAMA_URL=http://ollama:11434
OLLM_MODEL_NAME=qwen2.5:3b

# Env for vllm 
#VLLM_URL=
#VLLM_MODEL_NAME=


# Env for google
GOOGLE_MODEL_NAME=gemini-2.5-flash

# Env for openai
#OPENAI_MODEL_NAME=


VAULT_ADDR=http://vault:8200
OAUTH_42_REDIRECT_URI=https://api.ft_transcendence/v1/auth/oauth/42/callback

FRONTEND_URL=https://ft_transcendence
ALLOWED_ORIGINS=https://ft_transcendence,https://api.ft_transcendence

# Increase or decrease based on the available host memory (in bytes)
ES_MEM_LIMIT=2073741824
KB_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824
OLLAMA_MEM_LIMIT=6273741824


# SAMPLE Predefined Key only to be used in POC environments
