// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "mysql"
}

model User {
  id  String @id @default(uuid()) @db.VarChar(36)
  email  String @db.VarChar(255) @unique
  username  String @db.VarChar(32) @unique
  passwordHash  String? @db.VarChar(255) @map("password_hash")
  avatarUrl  String? @db.VarChar(255) @map("avatar_url")
  avatar  Avatar?
  isOnline  Boolean @default(false) @map("is_online")
  lastSeenAt  DateTime? @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  oauthAccounts  OAuthAccount[]
  refreshTokens  RefreshToken[]
  totpSecretEncrypted  String? @map("totp_secret_encrypted") @db.VarChar(255)
  totpEnabled Boolean  @default(false) @map("totp_enabled")
  lastTotpStepConsumed  BigInt? @map("last_totp_step_consumed")
  scratchCodes  ScratchCode[]
  friendshipsAsLow   Friendship[] @relation("FriendshipLow")
  friendshipsAsHigh  Friendship[] @relation("FriendshipHigh")
  @@map("users")
}

model RefreshToken {
  id String  @id @default(uuid()) @db.VarChar(36)
  userId String  @map("user_id") @db.VarChar(36)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String @unique @map("token_hash") @db.VarChar(64)
  familyId  String @map("family_id") @db.VarChar(36)
  replacedById  String? @unique @map("replaced_by") @db.VarChar(36)
  replacedBy  RefreshToken? @relation("TokenRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces  RefreshToken? @relation("TokenRotation")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([familyId])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id  String @id @default(uuid()) @db.VarChar(36)
  userId  String @map("user_id") @db.VarChar(36)
  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String @db.VarChar(32)
  providerId  String @map("provider_id") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model ScratchCode {
  id  String @id @default(uuid()) @db.VarChar(36)
  userId  String @map("user_id") @db.VarChar(36)
  codeHash  String @unique @map("code_hash") @db.VarChar(64)
  consumedAt  DateTime? @map("consumed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("scratch_codes")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model Friendship {
  userLow        String           @map("user_low") @db.VarChar(36)
  userHigh       String           @map("user_high") @db.VarChar(36)
  requestedById  String           @map("requested_by") @db.VarChar(36)
  status         FriendshipStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  userLowUser    User @relation("FriendshipLow", fields: [userLow], references: [id], onDelete: Cascade)
  userHighUser   User @relation("FriendshipHigh", fields: [userHigh], references: [id], onDelete: Cascade)

  @@id([userLow, userHigh])
  @@index([userHigh])
  @@map("friendships")
}

model Avatar {
  userId    String   @id @map("user_id") @db.VarChar(36)
  data      Bytes    @db.MediumBlob
  mimeType  String   @map("mime_type") @db.VarChar(255)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("avatars")
}
